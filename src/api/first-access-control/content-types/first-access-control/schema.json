{
  "kind": "collectionType",
  "collectionName": "first_access_controls",
  "info": {
    "singularName": "first-access-control",
    "pluralName": "first-access-controls",
    "displayName": "Acess Control"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "mustCompleteProfile": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "profileCompletedAt": {
      "type": "datetime"
    },
    "mustAcceptTerms": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "termsAcceptedAt": {
      "type": "datetime"
    },
    "termsVersionAccepted": {
      "type": "string"
    },
    "termsContentHashAccepted": {
      "type": "string"
    },
    "mustChangePassword": {
      "type": "boolean",
      "default": false
    },
    "tempPasswordExpiresAt": {
      "type": "datetime"
    },
    "tempPasswordIssuedAt": {
      "type": "datetime"
    },
    "tempPasswordUsedAt": {
      "type": "datetime"
    },
    "passwordResetCode": {
      "type": "string"
    },
    "passwordResetExpiresAt": {
      "type": "datetime"
    },
    "passwordResetRequestedAt": {
      "type": "datetime"
    },
    "passwordResetUsedAt": {
      "type": "datetime"
    }
  }
}
