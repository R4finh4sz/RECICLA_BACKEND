{
  "kind": "collectionType",
  "collectionName": "trusted_devices",
  "info": {
    "singularName": "trusted-device",
    "pluralName": "trusted-devices",
    "displayName": "Trusted Device"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "ip": { "type": "string", "required": true },
    "userAgent": { "type": "text", "required": true },
    "firstSeenAt": { "type": "datetime", "required": true },
    "lastSeenAt": { "type": "datetime", "required": true },
    "timesSeen": { "type": "integer", "default": 1 },
    "twoFactorSkipUntil": { "type": "datetime" }
  }
}