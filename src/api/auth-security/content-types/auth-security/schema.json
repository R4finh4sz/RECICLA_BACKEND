{
  "kind": "collectionType",
  "collectionName": "auth_securities",
  "info": {
    "singularName": "auth-security",
    "pluralName": "auth-securities",
    "displayName": "Auth Security"
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    },


    "failedLoginAttempts": { "type": "integer", "default": 0 },
    "loginBlockedUntil": { "type": "datetime" },

    "firstAccessFailedAttempts": { "type": "integer", "default": 0 },
    "firstAccessBlockedUntil": { "type": "datetime" },

    "passwordResetRequestsCount": { "type": "integer", "default": 0 },
    "passwordResetRequestsWindowStart": { "type": "datetime" },

    "emailConfirmationResendCount": { "type": "integer", "default": 0 },
    "emailConfirmationResendWindowStart": { "type": "datetime" },
    "emailConfirmationLastSentAt": { "type": "datetime" },

    "loginTwoFactorChallengeId": { "type": "string" },
    "loginTwoFactorCode": { "type": "string" },
    "loginTwoFactorExpiresAt": { "type": "datetime" },
    "loginTwoFactorRememberMe": { "type": "boolean", "default": false },

    "lastLoginAt": { "type": "datetime" },
    "lastLoginIp": { "type": "string" },
    "lastLoginUserAgent": { "type": "text" }
  }
}